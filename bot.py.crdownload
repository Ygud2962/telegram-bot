async def cmd_teacher(update: Update, context: CallbackContext):
    """Учитель вводит /teacher и своё имя для привязки Telegram-ID."""
    user = update.effective_user
    already = _tname(await asyncio.to_thread(db.find_teacher_by_telegram_id, user.id))
    if already:
        await update.message.reply_text(
            f"✅ Вы уже зарегистрированы как <b>{already}</b>.\n"
            f"Уведомления о заменах будут приходить автоматически.",
            parse_mode='HTML'
        )
        return

    context.user_data['registering_teacher'] = True
    # Показываем список
    teachers_db = await asyncio.to_thread(db.get_all_teachers_db)
    names = [t[0] for t in teachers_db]
    if not names:
        await update.message.reply_text("❌ Список учителей ещё не заполнен.")
        return

    kb = []
    for i in range(0, len(names), 2):
        row = [btn(names[i], f'reg_teacher_{i}')]
        if i + 1 < len(names):
            row.append(btn(names[i + 1], f'reg_teacher_{i+1}'))
        kb.append(row)
    kb.append([btn("❌ Отмена", 'back_to_main')])

    context.user_data['reg_teacher_names'] = names
    await update.message.reply_text(
        "👨‍🏫 <b>РЕГИСТРАЦИЯ УЧИТЕЛЯ</b>\n\n"
        "Найдите своё имя в списке и нажмите на него.\n"
        "После этого вы будете получать уведомления о своих заменах.",
        parse_mode='HTML',
        reply_markup=InlineKeyboardMarkup(kb)
    )


