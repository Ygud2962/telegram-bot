            [btn("🏠 Главное меню", 'back_to_main')],
        ]
        await safe_edit(query,
            "🌟 <b>МОЁ</b>\n\nИзбранного нет.\n"
            "Добавьте класс или учителя через меню расписания.", kb)
        return

    fav_classes  = [v for t, v in favs if t == 'class']
    fav_teachers = [v for t, v in favs if t == 'teacher']

    text = "🌟 <b>МОЁ — ИЗБРАННОЕ</b>\n\n"
    kb = []

    if fav_classes:
        text += "<b>📚 Классы:</b>\n" + "".join(f"• {c.upper()}\n" for c in fav_classes) + "\n"
        for c in fav_classes:
            kb.append([btn(f"📅 {c.upper()}", f'week_{c}'),
                       btn("🗑", f'del_fav_cls_{c}')])

    if fav_teachers:
        text += "<b>👨‍🏫 Учителя:</b>\n" + "".join(f"• {t}\n" for t in fav_teachers) + "\n"
        for t in fav_teachers:
            if t not in ALL_TEACHERS:
                continue
            idx = ALL_TEACHERS.index(t)
            kb.append([btn(f"👨‍🏫 {t}", f'tch_{idx}'),
                       btn("🗑", f'del_fav_tch_{idx}')])

    kb.append([btn("🏠 Главное меню", 'back_to_main')])
    await safe_edit(query, text, kb)


