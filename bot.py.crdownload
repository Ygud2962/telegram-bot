TEACHERS_PER_PAGE = 16


async def menu_teacher(query, context, page=0):
    start = page * TEACHERS_PER_PAGE
    chunk = ALL_TEACHERS[start:start + TEACHERS_PER_PAGE]
    kb = []
    for i in range(0, len(chunk), 2):
        row = [btn(chunk[i], f'tch_{start+i}')]
        if i + 1 < len(chunk):
            row.append(btn(chunk[i+1], f'tch_{start+i+1}'))
        kb.append(row)

    nav = []
    if page > 0:
        nav.append(btn("◀️", f'tch_page_{page-1}'))
    total_pages = (len(ALL_TEACHERS) + TEACHERS_PER_PAGE - 1) // TEACHERS_PER_PAGE
    nav.append(btn(f"{page+1}/{total_pages}", 'noop'))
    if start + TEACHERS_PER_PAGE < len(ALL_TEACHERS):
        nav.append(btn("▶️", f'tch_page_{page+1}'))
    if nav:
        kb.append(nav)
    kb.append([btn("🏠 Главное меню", 'back_to_main')])

    await safe_edit(query,
        f"👨‍🏫 <b>УЧИТЕЛЯ</b>  ({len(ALL_TEACHERS)} чел.)\n"
        f"Выберите учителя:", kb)


