def _clear_flow(context):
    """Сбрасывает только ключи текущего флоу, сохраняя кэши профиля и пр."""
    for k in _FLOW_KEYS:
        context.user_data.pop(k, None)


def lesson_time_str(num: int) -> str:
    if num in LESSON_TIMES:
        s, e = LESSON_TIMES[num]
        return f"{s}–{e}"
    return "00:00–00:00"


def lesson_emoji(num: int) -> str:
    if 1 <= num <= 7:
        return LESSON_EMOJIS[num - 1]
    return f"{num}."


def get_current_lesson_info() -> dict:
    now = datetime.now(TZ_MINSK)
    cur = now.hour * 60 + now.minute
    intervals = [
        (8, 0, 8, 45, 1), (9, 0, 9, 45, 2), (10, 0, 10, 45, 3),
        (11, 0, 11, 45, 4), (12, 0, 12, 45, 5), (12, 55, 13, 40, 6),
        (14, 0, 14, 45, 7)
    ]
    first_s = intervals[0][0] * 60 + intervals[0][1]  # 8:00

    # Идёт урок
    for sh, sm, eh, em, n in intervals:
        s = sh * 60 + sm
        e = eh * 60 + em
        if s <= cur <= e:
            return {'status': 'lesson', 'number': n,
                    'time_left': e - cur,
                    'start': f"{sh:02d}:{sm:02d}",
                    'end': f"{eh:02d}:{em:02d}"}

    # До начала школьного дня (00:00–08:00)
    if cur < first_s:
        return {'status': 'before_school',
                'minutes_until': first_s - cur,
                'start': f"{intervals[0][0]:02d}:{intervals[0][1]:02d}"}

    # Перемена между уроками
    for sh, sm, eh, em, n in intervals:
        s = sh * 60 + sm
        if cur < s:
            return {'status': 'break', 'next_number': n,
                    'minutes_until': s - cur,
                    'start': f"{sh:02d}:{sm:02d}",
                    'end': f"{eh:02d}:{em:02d}"}

    return {'status': 'finished'}


def convert_utc_to_minsk(utc_str) -> str:
    try:
        if hasattr(utc_str, 'strftime'):
            dt = utc_str
        else:
            dt = datetime.strptime(str(utc_str), '%Y-%m-%d %H:%M:%S')
        if dt.tzinfo is None:
            dt = pytz.utc.localize(dt)
        return dt.astimezone(TZ_MINSK).strftime('%d.%m.%Y %H:%M')
    except Exception:
        return str(utc_str)


async def safe_edit(query, text: str, keyboard=None, parse_mode='HTML'):
    markup = InlineKeyboardMarkup(keyboard) if keyboard else None
    if len(text) > 4096:
        text = text[:4000] + "\n\n<i>...текст обрезан</i>"
    try:
        await query.edit_message_text(text, reply_markup=markup, parse_mode=parse_mode)
    except BadRequest as e:
        err_str = str(e)
        # Игнорируем "не изменилось" и "сообщение не найдено" — не краш
        if any(x in err_str for x in ("Message is not modified",
                                       "message to edit not found",
                                       "MESSAGE_ID_INVALID")):
            return
        logger.warning(f"safe_edit BadRequest: {e}")
    except Exception as e:
        logger.warning(f"safe_edit error: {e}")


async def safe_send(context, chat_id, text: str, keyboard=None, parse_mode='HTML'):
    markup = InlineKeyboardMarkup(keyboard) if keyboard else None
    try:
        return await context.bot.send_message(
            chat_id=chat_id, text=text,
            reply_markup=markup, parse_mode=parse_mode
        )
    except Exception as e:
        logger.error(f"safe_send error: {e}")
        return None


# ══════════════════════════════════════════════════════════
#  РАСПИСАНИЕ: ФОРМАТИРОВАНИЕ
# ══════════════════════════════════════════════════════════
def get_teacher_schedule(teacher_name: str) -> dict:
    if teacher_name in _teacher_schedule_cache:
        return _teacher_schedule_cache[teacher_name]
    schedule: dict = {}
    for cls, days in SCHEDULE_STRUCTURED.items():
        for day, lessons in days.items():
            for num, subj, teachers_str in lessons:
                parts = [re.sub(r'\s*\([^)]*\)', '', t).strip()
                         for t in teachers_str.split('/')]
                if teacher_name in parts:
                    schedule.setdefault(day, []).append({
                        'class': cls, 'number': num,
                        'subject': subj, 'time': lesson_time_str(num),
                        'full_teacher': teachers_str
                    })
    for d in schedule:
        schedule[d].sort(key=lambda x: x['number'])
    _teacher_schedule_cache[teacher_name] = schedule
    return schedule


async def format_day_schedule(class_name: str, day: str,
                               lessons: list, target_date=None) -> str:
    lessons = sorted(lessons, key=lambda x: x[0])
    subs = {}
    if target_date:
        raw = await asyncio.to_thread(
            db.get_substitutions_for_class_date, class_name, target_date
        )
        for s in raw:
            subs[s[3]] = {
                'old_subject': s[4], 'new_subject': s[5],
                'old_teacher': s[6], 'new_teacher': s[7]
            }

    lines = [f"📅 <b>{day.upper()} — {class_name.upper()}</b>", "─" * 20]
    for num, subj, teacher in lessons:
        e = lesson_emoji(num)
        t = lesson_time_str(num)
        lines.append(f"{e} <b>{t}</b>  {subj}")
        lines.append(f"   👨‍🏫 {teacher}")
        if num in subs:
            s = subs[num]
            lines.append(f"   🔄 <b>ЗАМЕНА:</b> {s['new_subject']} — {s['new_teacher']}")
    return "\n".join(lines)


def format_week_schedule(class_name: str) -> str:
    if class_name not in SCHEDULE_STRUCTURED:
        return f"❌ Расписание для {class_name} не найдено."
    lines = [f"📅 <b>НЕДЕЛЯ — {class_name.upper()}</b>", "═" * 25]
    for day in DAYS_OF_WEEK:
        lessons = SCHEDULE_STRUCTURED[class_name].get(day, [])
        if not lessons:
            continue
        lines.append(f"\n<b>📌 {day.upper()}</b>")
        lines.append("─" * 18)
        for num, subj, teacher in sorted(lessons, key=lambda x: x[0]):
            e = lesson_emoji(num)
            t = lesson_time_str(num)
            lines.append(f"{e} <b>{t}</b>  {subj}")
            lines.append(f"   👨‍🏫 {teacher}")
    return "\n".join(lines)


async def format_teacher_schedule_text(teacher_name: str, schedule: dict) -> str:
    today = datetime.now(TZ_MINSK).date()
    now   = datetime.now(TZ_MINSK)
    cur_day = DAYS_OF_WEEK[now.weekday()] if now.weekday() < 5 else None
    cur_info = get_current_lesson_info()
    cur_lesson_num = cur_info.get('number') if cur_info['status'] == 'lesson' else None

    # Замены на 30 дней
    subs_raw = await asyncio.to_thread(
        db.get_teacher_substitutions_between,
        teacher_name,
        today.strftime('%Y-%m-%d'),
        (today + timedelta(days=30)).strftime('%Y-%m-%d')
    )
    subs_by_date: dict = {}
    for s in subs_raw:
        subs_by_date.setdefault(s[1], []).append(s)

    lines = [f"<b>👨‍🏫 {teacher_name}</b>", "═" * 30]

    if schedule:
        total = sum(len(v) for v in schedule.values())
        classes = sorted({l['class'] for v in schedule.values() for l in v})
        subjects = sorted({l['subject'] for v in schedule.values() for l in v})
        lines += [
            "<b>📊 Статистика недели:</b>",
            f"• Уроков: <b>{total}</b>",
            f"• Классы: <b>{', '.join(classes)}</b>",
            f"• Предметы: <b>{', '.join(subjects)}</b>",
        ]
        if subs_raw:
            lines.append(f"• ⚠️ Замен на 30 дней: <b>{len(subs_raw)}</b>")
    else:
        lines.append("<i>❌ Нет уроков в расписании</i>")

    lines += ["", "═" * 30, "<b>📅 ОСНОВНОЕ РАСПИСАНИЕ:</b>"]

    for day in DAYS_OF_WEEK:
        if day not in schedule or not schedule[day]:
            continue
        lines += [f"<b>{day.upper()}</b>", "─" * 18]
        for lesson in schedule[day]:
            e = lesson_emoji(lesson['number'])
            is_now = (day == cur_day and lesson['number'] == cur_lesson_num)
            prefix = "🟢 " if is_now else ""
            t = lesson['time']
            cls = lesson['class'].upper()
            subj = lesson['subject']
            lines.append(f"{prefix}{e} <b>{t}</b>  <code>{cls}</code> ➡️ {subj}")
        lines.append("")

    lines += ["═" * 30, "<b>🔄 ЗАМЕНЫ (30 дней):</b>"]
    shown = 0
    for i in range(30):
        d = today + timedelta(days=i)
        ds = d.strftime('%Y-%m-%d')
        if ds not in subs_by_date:
            continue
        if d.weekday() >= 5:
            continue
        day_name = DAYS_OF_WEEK[d.weekday()]
        lines += [f"<b>{day_name}</b> <i>({d.strftime('%d.%m')})</i>", "─" * 18]
        for s in subs_by_date[ds]:
            num = s[3]
            t = lesson_time_str(num)
            e = lesson_emoji(num)
            cls = s[8]
            if s[7] == teacher_name:
                lines.append(f"{e} <b>{t}</b> <code>{cls}</code> ➡️ {s[5]}")
                lines.append(f"   🔄 вместо {s[4]} ({s[6]})")
            else:
                lines.append(f"{e} <b>{t}</b> <code>{cls}</code> ➡️ {s[4]}")
                lines.append(f"   🔄 заменён: {s[7]} ({s[5]})")
        lines.append("")
        shown += 1
        if shown >= 7:
            break

    if shown == 0:
        lines.append("<i>На ближайшие 30 дней замен нет</i>")

    lines.append("<i>ℹ️ 🟢 — текущий урок</i>")
    return "\n".join(lines)


def format_substitution_row(sub: tuple) -> str:
    return (f"📌 <b>{sub[8].upper()}</b>, {sub[3]} урок ({lesson_time_str(sub[3])})\n"
            f"   {sub[4]} ({sub[6]})\n"
            f"   🔄 → {sub[5]} (<b>{sub[7]}</b>)")


# ══════════════════════════════════════════════════════════
#  ИИ-ПОМОЩНИК (Groq)
# ══════════════════════════════════════════════════════════
AI_HISTORY: dict = {}   # user_id -> list of messages (последние 6)

SYSTEM_PROMPT_DEFAULT = (
    "Ты — умный помощник для белорусской школы. "
    "Помогаешь как педагогам, так и школьникам. "
    "Отвечай на русском языке, кратко и по делу. "
    "Можешь помочь с объяснением тем, составлением планов уроков, "
    "методическими советами, решением задач. "
    "Используй примеры там, где это уместно."
)

SYSTEM_PROMPT_TEACHER = (
    "Ты — профессиональный ассистент для педагогов белорусской школы. "
    "Помогай с методическими материалами, планами уроков, объяснением сложных тем, "
    "составлением контрольных работ, советами по работе с учениками. "
    "Отвечай профессионально, на русском языке."
)


async def ask_ai(question: str, user_id: int, is_teacher: bool = False) -> str:
    if not GROQ_API_KEY:
        return "❌ ИИ-помощник не настроен. Установите GROQ_API_KEY."

    history = AI_HISTORY.get(user_id, [])
    history.append({"role": "user", "content": question})
    if len(history) > 12:
        history = history[-12:]

    sys_prompt = SYSTEM_PROMPT_TEACHER if is_teacher else SYSTEM_PROMPT_DEFAULT

    payload = {
        "model": GROQ_MODEL,
        "messages": [{"role": "system", "content": sys_prompt}] + history,
        "max_tokens": 800,
        "temperature": 0.7,
    }
    headers = {"Authorization": f"Bearer {GROQ_API_KEY}",
               "Content-Type": "application/json"}

    async with httpx.AsyncClient(timeout=30.0) as client:
        try:
            r = await client.post(
                "https://api.groq.com/openai/v1/chat/completions",
                json=payload, headers=headers
            )
            if r.status_code == 429:
                return "⏳ Превышен лимит запросов. Попробуйте через минуту."
            if r.status_code == 401:
                return "❌ Ошибка API-ключа Groq."
            if r.status_code >= 400:
                return f"❌ Ошибка API ({r.status_code}). Попробуйте позже."
            r.raise_for_status()
            answer = r.json()['choices'][0]['message']['content'].strip()
            if not answer:
                return "❌ Пустой ответ ИИ. Перефразируйте вопрос."
            # Сохраняем ответ в историю
            history.append({"role": "assistant", "content": answer})
            AI_HISTORY[user_id] = history[-12:]
            if len(answer) > 4000:
                answer = answer[:4000] + "\n\n<i>...ответ обрезан</i>"
            return answer
        except httpx.TimeoutException:
            return "⏳ Превышено время ожидания. Попробуйте позже."
        except Exception as e:
            logger.error(f"ask_ai error: {e}")
            return f"❌ Ошибка ИИ: {str(e)[:100]}"


# ══════════════════════════════════════════════════════════
#  ТЕХРЕЖИМ
# ══════════════════════════════════════════════════════════
async def check_maintenance(update: Update, context: CallbackContext,
                            is_admin: bool | None = None) -> bool:
    global _maintenance_cache
    now = datetime.now()
    if (now - _maintenance_cache['last_check']).total_seconds() > MAINTENANCE_TTL:
        status = await asyncio.to_thread(db.get_maintenance_status)
        status['last_check'] = now
        _maintenance_cache = status

    if is_admin is None:
        is_admin = await is_bot_admin_async(update.effective_user.id)
    if is_admin:
        return False
    if not _maintenance_cache.get('enabled'):
        return False

    msg = "⚠️ <b>ТЕХНИЧЕСКИЕ РАБОТЫ</b>\n\nБот временно недоступен.\n"
    if _maintenance_cache.get('until'):
        msg += f"🕗 Восстановление: <b>{_maintenance_cache['until']}</b>\n"
    msg += "\nПриносим извинения за неудобства."
    kb = [[btn("🔄 Проверить статус", 'check_maintenance_status')]]

    try:
        if update.callback_query:
            await update.callback_query.answer("⚠️ Технические работы", show_alert=True)
            await safe_edit(update.callback_query, msg, kb)
        else:
            await update.message.reply_text(
                msg, parse_mode='HTML',
                reply_markup=InlineKeyboardMarkup(kb)
            )
    except Exception:
        pass
    return True


# ══════════════════════════════════════════════════════════
#  УВЕДОМЛЕНИЯ
# ══════════════════════════════════════════════════════════
async def notify_teacher_substitution(context, teacher_name: str, sub_data: dict):
    tid = await asyncio.to_thread(db.get_teacher_telegram_id, teacher_name)
    if not tid:
        for a in (await get_admin_ids()):
            try:
                await context.bot.send_message(
                    chat_id=a,
                    text=f"⚠️ Замена добавлена для «{teacher_name}», "
                         f"но уведомление не отправлено — нет Telegram ID.",
                    parse_mode='HTML'
                )
            except Exception:
                pass
        return

    t = lesson_time_str(sub_data['lesson'])
    msg = (
        f"<b>🔔 ВАМ НАЗНАЧЕНА ЗАМЕНА!</b>\n"
        f"📅 {sub_data['date']} ({sub_data['day']})\n"
        f"🕐 {t}  (урок {sub_data['lesson']})\n"
        f"🏫 Класс: {sub_data['class_name'].upper()}\n"
        f"📚 {sub_data['old_subject']} → <b>Вы проводите</b>\n"
        f"<i>Добавлено администратором.</i>"
    )
    try:
        await context.bot.send_message(chat_id=tid, text=msg, parse_mode='HTML')
    except Exception as e:
        logger.error(f"notify_teacher: {e}")
        for a in (await get_admin_ids()):
            try:
                await context.bot.send_message(
                    chat_id=a,
                    text=f"❌ Не удалось отправить уведомление «{teacher_name}»: {str(e)[:100]}",
                    parse_mode='HTML'
                )
            except Exception:
                pass


async def notify_class_substitution(context, class_name: str, sub_data: dict):
    """Уведомляет всех подписчиков класса о замене."""
    subscribers = await asyncio.to_thread(db.get_class_subscribers, class_name)
    if not subscribers:
        return

    t = lesson_time_str(sub_data['lesson'])
    msg = (
        f"🔔 <b>ЗАМЕНА В {class_name.upper()}</b>\n\n"
        f"📅 {sub_data['date']} ({sub_data['day']})\n"
        f"🕐 {t}  (урок {sub_data['lesson']})\n"
        f"📚 {sub_data['old_subject']}\n"
        f"👨‍🏫 Новый учитель: <b>{sub_data.get('new_teacher','—')}</b>"
    )
    kb = [[btn("📋 Все замены", 'menu_substitutions')]]
    for uid in subscribers:
        try:
            await context.bot.send_message(
                chat_id=uid, text=msg, parse_mode='HTML',
                reply_markup=InlineKeyboardMarkup(kb)
            )
            await asyncio.sleep(0.05)
        except Exception as e:
            logger.warning(f"notify_class_sub {uid}: {e}")




async def notify_new_news(context, title: str):
    """Рассылка уведомления о новой новости всем пользователям (с ограничением скорости)."""
    users = await asyncio.to_thread(db.get_all_users)
    msg = f"📣 <b>Новая новость школы:</b>\n<b>{title}</b>\n\n👉 Откройте раздел «Новости» в боте."
    kb = [[btn("📰 Открыть новости", 'menu_news')]]
    sent = failed = 0
    for i, (uid, *_) in enumerate(users):
        try:
            await context.bot.send_message(
                chat_id=uid, text=msg, parse_mode='HTML',
                reply_markup=InlineKeyboardMarkup(kb)
            )
            sent += 1
        except (Forbidden, BadRequest):
            failed += 1
        except Exception:
            failed += 1
        if i % 20 == 0:
            await asyncio.sleep(1)   # Соблюдение лимитов Telegram
    logger.info(f"Рассылка новости: отправлено {sent}, ошибок {failed}")
    return sent, failed


