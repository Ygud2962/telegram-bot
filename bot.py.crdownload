async def menu_day_schedule(query, context):
    raw_day = query.data.replace('day_', '')
    day = raw_day.capitalize()
    cls = context.user_data.get('sel_class', '')

    today = datetime.now().date()
    day_map = {d.lower(): i for i, d in enumerate(DAYS_OF_WEEK)}
    wd_target = day_map.get(raw_day, 0)
    diff = (wd_target - today.weekday()) % 7
    target = today + timedelta(days=diff)
    target_str = target.strftime('%Y-%m-%d')

    lessons = SCHEDULE_STRUCTURED.get(cls, {}).get(day, [])
    text = await format_day_schedule(cls, day, lessons, target_str)

    is_fav = await asyncio.to_thread(db.is_favorite, query.from_user.id, 'class', cls)
    fav_text = "🗑 Убрать из избранного" if is_fav else "⭐ В избранное"

    kb = [
        [btn(fav_text, f'fav_cls_{cls}')],
        [btn("📅 Вся неделя", f'week_{cls}')],
        [btn("↩️ К дням", f'cls_{cls}'), btn("🏠 Меню", 'back_to_main')],
    ]
    await safe_edit(query, text, kb)


