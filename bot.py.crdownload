async def show_current_lesson(query, context):
    class_name = query.data.replace('now_', '')
    context.user_data['now_class'] = class_name

    now = datetime.now(TZ_MINSK)
    wd = now.weekday()
    if wd >= 5:
        day_str = "Суббота" if wd == 5 else "Воскресенье"
        next_start = _next_school_monday_start(now)
        minutes_left = max(0, int((next_start - now).total_seconds() // 60))
        kb = [
            [btn("🔄 Обновить", f'now_{class_name}')],
            [btn("↩️ К выбору класса", 'menu_now')],
            [btn("🏠 Главное меню", 'back_to_main')],
        ]
        await safe_edit(
            query,
            f"📅 <b>{day_str}</b>\n"
            f"🏖️ Сегодня уроков нет.\n"
            f"🔔 Следующий учебный день: <b>понедельник, {next_start.strftime('%d.%m')} в 08:00</b>\n"
            f"⏳ До первого урока: <b>{_fmt_minutes(minutes_left)}</b>",
            kb,
        )
        return

    day_name = DAYS_OF_WEEK[wd]
    info = get_current_lesson_info()
    today_str = now.strftime('%Y-%m-%d')

    if info['status'] == 'finished':
        text = (f"✅ <b>Уроки закончились</b>\n"
                f"📅 {day_name}, {now.strftime('%d.%m')}\n"
                f"<i>Обновлено: {now.strftime('%H:%M:%S')}</i>")
    elif info['status'] == 'break':
        nxt = info['next_number']
        text = (f"⏸️ <b>ПЕРЕМЕНА</b>\n"
                f"📅 {day_name}\n"
                f"⏱️ Следующий урок <b>({nxt})</b> через <b>{_fmt_minutes(info['minutes_until'])}</b>\n"
                f"🕐 Начало: {info['start']}\n")
        lessons = SCHEDULE_STRUCTURED.get(class_name, {}).get(day_name, [])
        nxt_lesson = next((l for l in lessons if l[0] == nxt), None)
        if nxt_lesson:
            text += f"📚 <b>{nxt_lesson[1]}</b>\n👨‍🏫 {nxt_lesson[2]}\n"
            subs = await asyncio.to_thread(db.get_substitutions_for_class_date,
                                           class_name, today_str)
            sub = next((s for s in subs if s[3] == nxt), None)
            if sub:
                text += f"⚠️ <b>ЗАМЕНА:</b> {sub[5]} — {sub[7]}\n"
        text += f"<i>Обновлено: {now.strftime('%H:%M:%S')}</i>"
    else:
        num = info['number']
        text = (f"🔔 <b>ИДЁТ УРОК №{num}</b>\n"
                f"📅 {day_name}\n"
                f"⏱️ Осталось <b>{_fmt_minutes(info['time_left'])}</b>  ({info['start']}–{info['end']})\n")
        lessons = SCHEDULE_STRUCTURED.get(class_name, {}).get(day_name, [])
        cur_lesson = next((l for l in lessons if l[0] == num), None)
        if cur_lesson:
            text += f"📚 <b>{cur_lesson[1]}</b>\n👨‍🏫 {cur_lesson[2]}\n"
            subs = await asyncio.to_thread(db.get_substitutions_for_class_date,
                                           class_name, today_str)
            sub = next((s for s in subs if s[3] == num), None)
            if sub:
                text += f"⚠️ <b>ЗАМЕНА:</b> {sub[5]} — {sub[7]}\n"
        text += f"<i>Обновлено: {now.strftime('%H:%M:%S')}</i>"

    kb = [
        [btn("🔄 Обновить", f'now_{class_name}')],
        [btn("↩️ К выбору класса", 'menu_now')],
        [btn("🏠 Главное меню", 'back_to_main')],
    ]
    await safe_edit(query, text, kb)


