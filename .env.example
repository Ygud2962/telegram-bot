BOT_TOKEN=your_telegram_bot_token
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional AI assistant key
GROQ_API_KEY=

# Public game and backend URLs
GAME_URL=https://your-domain.up.railway.app
BOT_PUBLIC_URL=https://your-domain.up.railway.app

# Runtime
PORT=8080
BOT_VERSION=8.0.0
GAME_VERSION=1.2.15

# Game access and auth
GAME_BETA=0
GAME_AUTH_REQUIRED=1
GAME_AUTH_TTL_SEC=86400

# Diagnostics / tuning
SLOW_DB_MS=350
SLOW_CALLBACK_MS=1000
MAX_AI_HISTORY_USERS=2000
AI_HISTORY_TTL_SEC=86400
